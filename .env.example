# ─────────────────────────────────────────────────────────────
# RingLeader — environment configuration
# Copy to `.env` and fill in. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# ── Neo4j (REQUIRED) ─────────────────────────────────────────
# From console.neo4j.io after creating a free AuraDB instance.
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-password
NEO4J_DATABASE=neo4j

# ── AI gateway (Butterbase, OpenAI-compatible) ───────────────
# Butterbase exposes an OpenAI-compatible endpoint. Point the
# base URL at your Butterbase AI gateway and use your app key.
# For local dev before Butterbase is wired, you can point these
# at any OpenAI-compatible endpoint.
AI_GATEWAY_BASE_URL=https://api.butterbase.ai/v1
AI_GATEWAY_API_KEY=your-butterbase-app-key
AI_MODEL=claude-3-5-sonnet

# ── RocketRide Cloud ─────────────────────────────────────────
# Deployed pipeline endpoint + token (filled after deploy).
ROCKETRIDE_ENDPOINT=https://api.rocketride.ai/pipelines/ringleader-investigation
ROCKETRIDE_TOKEN=your-rocketride-token

# ── Server ───────────────────────────────────────────────────
PORT=8787
